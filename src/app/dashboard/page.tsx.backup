'use client'

import { useSession } from 'next-auth/react'
import { DashboardLayout } from '@/components/layout/dashboard-layout'
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'
import { Button } from '@/components/ui/button'
import { 
  Users, 
  BookOpen, 
  TrendingUp, 
  DollarSign, 
  Clock, 
  Award,
  Play,
  Calendar,
  Target,
  MessageSquare,
  Star,
  CheckCircle,
  ArrowRight,
  BarChart3
} from 'lucide-react'

function DashboardContent() {
  const { data: session } = useSession()
  const userRole = session?.user?.role || 'STUDENT'

  const getStatsByRole = () => {
    switch (userRole) {
      case 'ADMIN':
        return [
          { title: 'Total Users', value: '1,234', change: '+12%', icon: Users, color: 'bg-primary-800' },
          { title: 'Total Courses', value: '45', change: '+8%', icon: BookOpen, color: 'bg-secondary-500' },
          { title: 'Revenue', value: 'Rp 45.2M', change: '+23%', icon: DollarSign, color: 'bg-accent-600' },
          { title: 'Active Students', value: '892', change: '+15%', icon: TrendingUp, color: 'bg-coffee-600' },
        ]
      case 'TUTOR':
        return [
          { title: 'My Courses', value: '12', change: '+2', icon: BookOpen, color: 'bg-primary-800' },
          { title: 'Total Students', value: '234', change: '+18', icon: Users, color: 'bg-secondary-500' },
          { title: 'Earnings', value: 'Rp 12.5M', change: '+25%', icon: DollarSign, color: 'bg-accent-600' },
          { title: 'Avg. Rating', value: '4.8', change: '+0.2', icon: Award, color: 'bg-coffee-600' },
        ]
      case 'STUDENT':
        return [
          { title: 'Enrolled Courses', value: '8', change: '+2', icon: BookOpen, color: 'bg-primary-800' },
          { title: 'Completed', value: '5', change: '+1', icon: Award, color: 'bg-secondary-500' },
          { title: 'Learning Hours', value: '124', change: '+12', icon: Clock, color: 'bg-accent-600' },
          { title: 'Certificates', value: '5', change: '+1', icon: Award, color: 'bg-coffee-600' },
        ]
      default:
        return []
    }
  }

  const getRecentActivity = () => {
    switch (userRole) {
      case 'STUDENT':
        return [
          { title: 'Completed React Hooks lesson', time: '2 hours ago', icon: CheckCircle, color: 'text-green-600' },
          { title: 'Enrolled in UI/UX Design course', time: '5 hours ago', icon: BookOpen, color: 'text-blue-600' },
          { title: 'Earned JavaScript certificate', time: '1 day ago', icon: Award, color: 'text-purple-600' },
          { title: 'Posted in discussion forum', time: '2 days ago', icon: MessageSquare, color: 'text-orange-600' },
        ]
      case 'TUTOR':
        return [
          { title: 'New student enrolled', time: '1 hour ago', icon: Users, color: 'text-blue-600' },
          { title: 'Course rating updated', time: '3 hours ago', icon: Star, color: 'text-yellow-600' },
          { title: 'Published new lesson', time: '1 day ago', icon: Play, color: 'text-green-600' },
        ]
      case 'ADMIN':
        return [
          { title: 'New user registration', time: '30 minutes ago', icon: Users, color: 'text-blue-600' },
          { title: 'Revenue milestone reached', time: '2 hours ago', icon: DollarSign, color: 'text-green-600' },
          { title: 'System update completed', time: '5 hours ago', icon: CheckCircle, color: 'text-purple-600' },
        ]
      default:
        return []
    }
  }

  const getQuickActions = () => {
    switch (userRole) {
      case 'STUDENT':
        return [
          { title: 'Browse Courses', description: 'Discover new courses', icon: BookOpen, color: 'bg-primary-800', href: '/dashboard/courses' },
          { title: 'Continue Learning', description: 'Resume your progress', icon: Play, color: 'bg-secondary-500', href: '/dashboard/learning' },
          { title: 'View Schedule', description: 'Check your calendar', icon: Calendar, color: 'bg-accent-600', href: '/dashboard/schedule' },
          { title: 'Join Discussion', description: 'Connect with peers', icon: MessageSquare, color: 'bg-coffee-600', href: '/dashboard/discussions' },
        ]
      case 'TUTOR':
        return [
          { title: 'Create Course', description: 'Build new content', icon: BookOpen, color: 'bg-primary-800', href: '/dashboard/courses/create' },
          { title: 'Student Progress', description: 'Track performance', icon: BarChart3, color: 'bg-secondary-500', href: '/dashboard/analytics' },
          { title: 'Manage Schedule', description: 'Set office hours', icon: Calendar, color: 'bg-accent-600', href: '/dashboard/schedule' },
        ]
      case 'ADMIN':
        return [
          { title: 'Manage Users', description: 'User administration', icon: Users, color: 'bg-primary-800', href: '/dashboard/users' },
          { title: 'View Analytics', description: 'System insights', icon: BarChart3, color: 'bg-secondary-500', href: '/dashboard/analytics' },
          { title: 'Course Management', description: 'Content oversight', icon: BookOpen, color: 'bg-accent-600', href: '/dashboard/courses' },
        ]
      default:
        return []
    }
  }

  const stats = getStatsByRole()
  const recentActivity = getRecentActivity()
  const quickActions = getQuickActions()

  return (
    <div className="max-w-7xl mx-auto space-y-6">
        {/* Welcome Header */}
        <div className="bg-white rounded-2xl shadow-brown p-6 border border-secondary-200 backdrop-blur-sm">
          <div className="flex items-center justify-between">
            <div>
              <h1 className="text-3xl font-bold text-primary-900">
                Welcome back, {session?.user?.name || 'User'}! 👋
              </h1>
              <p className="text-secondary-600 mt-2">
                Here's your learning dashboard for today. Keep up the great work!
              </p>
            </div>
            <div className="text-right">
              <div className="text-sm text-secondary-600">Current Streak</div>
              <div className="text-2xl font-bold text-accent-600">🔥 7 days</div>
            </div>
          </div>
        </div>

        {/* Stats Grid */}
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {stats.map((stat, index) => (
            <Card key={index} className="hover:shadow-brown-lg transition-all duration-200 border border-secondary-200 bg-white backdrop-blur-sm">
              <CardContent className="p-6">
                <div className="flex items-center justify-between">
                  <div className="flex-1">
                    <p className="text-sm font-medium text-secondary-600">{stat.title}</p>
                    <p className="text-3xl font-bold text-primary-900 mt-2">{stat.value}</p>
                    <div className="flex items-center mt-2">
                      <span className="text-sm font-medium text-accent-600">{stat.change}</span>
                      <span className="text-xs text-secondary-500 ml-1">from last month</span>
                    </div>
                  </div>
                  <div className={`p-3 rounded-xl ${stat.color} bg-opacity-10`}>
                    <stat.icon className={`w-6 h-6 text-white`} />
                  </div>
                </div>
              </CardContent>
            </Card>
          ))}
        </div>

        {/* Main Content Grid */}
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          {/* Recent Activity */}
          <div className="lg:col-span-2">
            <Card className="border border-secondary-200 bg-white shadow-brown backdrop-blur-sm">
              <CardHeader className="pb-4">
                <CardTitle className="text-lg font-semibold text-primary-900">Recent Activity</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-4">
                  {recentActivity.map((activity, index) => {
                    const Icon = activity.icon
                    return (
                      <div key={index} className="flex items-start space-x-4 p-4 bg-primary-50 rounded-lg hover:bg-primary-100 transition-colors duration-200">
                        <div className={`p-2 rounded-lg ${activity.color} bg-opacity-10`}>
                          <Icon className={`w-5 h-5 text-white`} />
                        </div>
                        <div className="flex-1 min-w-0">
                          <p className="font-medium text-primary-900">{activity.title}</p>
                          <p className="text-sm text-secondary-600 mt-1">{activity.time}</p>
                        </div>
                      </div>
                    )
                  })}
                </div>
              </CardContent>
            </Card>
          </div>

          {/* Quick Actions */}
          <div>
            <Card className="border border-secondary-200 bg-white shadow-brown backdrop-blur-sm">
              <CardHeader className="pb-4">
                <CardTitle className="text-lg font-semibold text-primary-900">Quick Actions</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-3">
                  {quickActions.map((action, index) => {
                    const Icon = action.icon
                    return (
                      <Button
                        key={index}
                        variant="outline"
                        className="w-full justify-start h-auto p-4 hover:bg-primary-50 transition-colors duration-200 border-secondary-200"
                        onClick={() => alert(`Navigating to ${action.title}...`)}
                      >
                        <div className="flex items-center space-x-3 w-full">
                          <div className={`p-2 rounded-lg ${action.color} bg-opacity-10`}>
                            <Icon className={`w-5 h-5 text-white`} />
                          </div>
                          <div className="flex-1 text-left">
                            <p className="font-medium text-primary-900">{action.title}</p>
                            <p className="text-sm text-secondary-600">{action.description}</p>
                          </div>
                          <ArrowRight className="w-4 h-4 text-secondary-400" />
                        </div>
                      </Button>
                    )
                  })}
                </div>
              </CardContent>
            </Card>
          </div>
        </div>

        {/* Progress Overview (Student Only) */}
        {userRole === 'STUDENT' && (
          <Card className="border border-secondary-200 bg-white shadow-brown backdrop-blur-sm">
            <CardHeader className="pb-4">
              <CardTitle className="text-lg font-semibold text-primary-900">Current Progress</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div className="text-center">
                  <div className="w-20 h-20 mx-auto mb-3 relative">
                    <svg className="transform -rotate-90 w-20 h-20">
                      <circle cx="40" cy="40" r="36" stroke="#EAE3DC" strokeWidth="8" fill="none" />
                      <circle cx="40" cy="40" r="36" stroke="#3C2A21" strokeWidth="8" fill="none" 
                        strokeDasharray={`${2 * Math.PI * 36 * 0.75} ${2 * Math.PI * 36 * 0.25}`} />
                    </svg>
                    <div className="absolute inset-0 flex items-center justify-center">
                      <span className="text-xl font-bold text-primary-900">75%</span>
                    </div>
                  </div>
                  <p className="font-medium text-primary-900">React Course</p>
                  <p className="text-sm text-secondary-600">18 of 24 lessons</p>
                </div>
                
                <div className="text-center">
                  <div className="w-20 h-20 mx-auto mb-3 relative">
                    <svg className="transform -rotate-90 w-20 h-20">
                      <circle cx="40" cy="40" r="36" stroke="#EAE3DC" strokeWidth="8" fill="none" />
                      <circle cx="40" cy="40" r="36" stroke="#8E735B" strokeWidth="8" fill="none" 
                        strokeDasharray={`${2 * Math.PI * 36 * 0.5} ${2 * Math.PI * 36 * 0.5}`} />
                    </svg>
                    <div className="absolute inset-0 flex items-center justify-center">
                      <span className="text-xl font-bold text-primary-900">50%</span>
                    </div>
                  </div>
                  <p className="font-medium text-primary-900">UI/UX Design</p>
                  <p className="text-sm text-secondary-600">8 of 16 lessons</p>
                </div>
                
                <div className="text-center">
                  <div className="w-20 h-20 mx-auto mb-3 relative">
                    <svg className="transform -rotate-90 w-20 h-20">
                      <circle cx="40" cy="40" r="36" stroke="#EAE3DC" strokeWidth="8" fill="none" />
                      <circle cx="40" cy="40" r="36" stroke="#E89F6F" strokeWidth="8" fill="none" 
                        strokeDasharray={`${2 * Math.PI * 36 * 0.9} ${2 * Math.PI * 36 * 0.1}`} />
                    </svg>
                    <div className="absolute inset-0 flex items-center justify-center">
                      <span className="text-xl font-bold text-primary-900">90%</span>
                    </div>
                  </div>
                  <p className="font-medium text-primary-900">Digital Marketing</p>
                  <p className="text-sm text-secondary-600">9 of 10 lessons</p>
                </div>
              </div>
            </CardContent>
          </Card>
        )}
      </div>
    </div>
    </div>
  )
}

export default function Dashboard() {
  return (
    <DashboardLayout>
      <DashboardContent />
    </DashboardLayout>
  )
}
